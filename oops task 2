# -------------------- ENCAPSULATION --------------------

class StudentMarks:
    def __init__(self, marks):
        self.__marks = marks

    def update_marks(self, new_marks):
        if 0 <= new_marks <= 100:
            self.__marks = new_marks

    def get_marks(self):
        return self.__marks

class BankEncap:
    def __init__(self, balance):
        self.__balance = balance

    def deposit(self, amount):
        self.__balance += amount

    def withdraw(self, amount):
        if amount <= self.__balance:
            self.__balance -= amount

    def check_balance(self):
        return self.__balance

class EmployeeSalary:
    def __init__(self, salary):
        self.__salary = salary

    def update_salary(self, new_salary):
        if new_salary > 0:
            self.__salary = new_salary

    def get_salary(self):
        return self.__salary

class MobilePrice:
    def __init__(self, price):
        self.__price = price

    def update_price(self, new_price):
        if new_price > 0:
            self.__price = new_price

    def get_price(self):
        return self.__price

class CarPrice:
    def __init__(self, price):
        self.__price = price

    def set_price(self, price):
        if price > 0:
            self.__price = price

    def get_price(self):
        return self.__price

class Patient:
    def __init__(self, name, illness):
        self.__name = name
        self.__illness = illness

    def get_patient_info(self):
        return self.__name, self.__illness

# -------------------- ABSTRACTION --------------------

class AbstractAnimal(ABC):
    @abstractmethod
    def sound(self):
        pass

class AbstractShape(ABC):
    @abstractmethod
    def area(self):
        pass

class AbstractVehicle(ABC):
    @abstractmethod
    def start(self):
        pass

    @abstractmethod
    def stop(self):
        pass

class FullTimeEmployee(ABC):
    @abstractmethod
    def salary(self):
        pass

class ContractEmployee(ABC):
    @abstractmethod
    def salary(self):
        pass

class Payment(ABC):
    @abstractmethod
    def pay(self):
        pass

class Device(ABC):
    @abstractmethod
    def operate(self):
        pass

class Notification(ABC):
    @abstractmethod
    def send(self):
        pass

