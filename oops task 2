from abc import ABC, abstractmethod
import math

# -------------------- CLASS & OBJECT --------------------

class Student:
    def __init__(self, sid, name, department, marks):
        self.sid = sid
        self.name = name
        self.department = department
        self.marks = marks

    def display(self):
        print(self.sid, self.name, self.department, self.marks)

class Rectangle:
    def __init__(self, length, breadth):
        self.length = length
        self.breadth = breadth

    def area(self):
        return self.length * self.breadth

class Circle:
    def __init__(self, radius):
        self.radius = radius

    def area(self):
        return math.pi * self.radius * self.radius

    def circumference(self):
        return 2 * math.pi * self.radius

class Employee:
    def __init__(self, eid, name, designation, salary):
        self.eid = eid
        self.name = name
        self.designation = designation
        self.salary = salary

    def display(self):
        print(self.eid, self.name, self.designation, self.salary)

class Car:
    def __init__(self, brand, model, year, price):
        self.brand = brand
        self.model = model
        self.year = year
        self.price = price

    def display(self):
        print(self.brand, self.model, self.year, self.price)

class Mobile:
    def __init__(self, brand, storage, ram, price):
        self.brand = brand
        self.storage = storage
        self.ram = ram
        self.price = price

    def display(self):
        print(self.brand, self.storage, self.ram, self.price)

class BankAccountSimple:
    def __init__(self, acc_no, customer_name, balance):
        self.acc_no = acc_no
        self.customer_name = customer_name
        self.balance = balance

    def deposit(self, amount):
        self.balance += amount

    def withdraw(self, amount):
        if amount <= self.balance:
            self.balance -= amount
        else:
            print("Insufficient balance")

    def display(self):
        print(self.acc_no, self.customer_name, self.balance)

class Book:
    def __init__(self, book_id, title, author, category):
        self.book_id = book_id
        self.title = title
        self.author = author
        self.category = category

    def display(self):
        print(self.book_id, self.title, self.author, self.category)

# -------------------- INHERITANCE --------------------

class Animal:
    def eat(self):
        print("Animal eats")

    def sleep(self):
        print("Animal sleeps")

class Dog(Animal):
    def bark(self):
        print("Dog barks")

class Cat(Animal):
    def meow(self):
        print("Cat meows")

class Bird(Animal):
    def fly(self):
        print("Bird flies")

class VehicleBase:
    def __init__(self, reg_no, fuel_type):
        self.reg_no = reg_no
        self.fuel_type = fuel_type

class CarVehicle(VehicleBase):
    def __init__(self, reg_no, fuel_type, seating_capacity):
        super().__init__(reg_no, fuel_type)
        self.seating_capacity = seating_capacity

class Truck(VehicleBase):
    def __init__(self, reg_no, fuel_type, load_capacity):
        super().__init__(reg_no, fuel_type)
        self.load_capacity = load_capacity

class Person:
    def __init__(self, name, age):
        self.name = name
        self.age = age

class StudentCollege(Person):
    def __init__(self, name, age, roll_no, marks):
        super().__init__(name, age)
        self.roll_no = roll_no
        self.marks = marks

class EmployeePayroll:
    def __init__(self, eid, name, salary):
        self.eid = eid
        self.name = name
        self.salary = salary

class Manager(EmployeePayroll):
    def __init__(self, eid, name, salary, bonus):
        super().__init__(eid, name, salary)
        self.bonus = bonus

class Supervisor(EmployeePayroll):
    def __init__(self, eid, name, salary, allowance):
        super().__init__(eid, name, salary)
        self.allowance = allowance

class ShapeBase:
    pass

class CircleShape(ShapeBase):
    def __init__(self, radius):
        self.radius = radius

    def area(self):
        return math.pi * self.radius * self.radius

class RectangleShape(ShapeBase):
    def __init__(self, length, breadth):
        self.length = length
        self.breadth = breadth

    def area(self):
        return self.length * self.breadth

class Account:
    def __init__(self, acc_no, name, balance):
        self.acc_no = acc_no
        self.name = name
        self.balance = balance

class SavingsAccount(Account):
    def interest(self, rate):
        return self.balance * rate / 100

class CurrentAccount(Account):
    def overdraft(self, limit):
        return limit

class PersonSchool:
    def __init__(self, name):
        self.name = name

class Teacher(PersonSchool):
    def teach(self):
        print(self.name, "teaches")

class StudentSchool(PersonSchool):
    def study(self):
        print(self.name, "studies")

class Product:
    def __init__(self, pid, name, price):
        self.pid = pid
        self.name = name
        self.price = price

class Electronics(Product):
    def __init__(self, pid, name, price, warranty):
        super().__init__(pid, name, price)
        self.warranty = warranty

class Clothing(Product):
    def __init__(self, pid, name, price, size):
        super().__init__(pid, name, price)
        self.size = size

# -------------------- POLYMORPHISM --------------------

class Calculator:
    def add(self, *args):
        return sum(args)

class GeoCircle:
    def __init__(self, radius):
        self.radius = radius

    def area(self):
        return math.pi * self.radius * self.radius

class GeoRectangle:
    def __init__(self, length, breadth):
        self.length = length
        self.breadth = breadth

    def area(self):
        return self.length * self.breadth

class GeoTriangle:
    def __init__(self, base, height):
        self.base = base
        self.height = height

    def area(self):
        return 0.5 * self.base * self.height

