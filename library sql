import mysql.connector
from mysql.connector import Error, IntegrityError
from datetime import date


class Database:
    def __init__(self, host="localhost", user="root", password="", database="library_db"):
        self.config = {
            "host": host,
            "user": user,
            "password": password,
            "database": database
        }

    def get_connection(self):
        return mysql.connector.connect(**self.config)


class Book:
    def __init__(self, db):
        self.db = db

    def add_book(self, title, author, isbn, copies):
        conn = None
        cursor = None
        try:
            conn = self.db.get_connection()
            cursor = conn.cursor()
            cursor.execute(
                "INSERT INTO books (title, author, isbn, copies, available_copies) VALUES (%s, %s, %s, %s, %s)",
                (title, author, isbn, copies, copies)
            )
            conn.commit()
            print("Book added successfully.")
        except IntegrityError:
            print("Book already exists or invalid ISBN.")
        except Error as e:
            print("Error:", e)
        finally:
            if cursor:
                cursor.close()
            if conn:
                conn.close()

    def view_books(self):
        conn = None
        cursor = None
        try:
            conn = self.db.get_connection()
            cursor = conn.cursor()
            cursor.execute("SELECT * FROM books")
            rows = cursor.fetchall()
            if rows:
                for row in rows:
                    print(row)
            else:
                print("No books found.")
        except Error as e:
            print("Error:", e)
        finally:
            if cursor:
                cursor.close()
            if conn:
                conn.close()

    def search_book(self, keyword):
        conn = None
        cursor = None
        try:
            conn = self.db.get_connection()
            cursor = conn.cursor()
            q = "SELECT * FROM books WHERE title LIKE %s OR author LIKE %s OR isbn LIKE %s"
            val = f"%{keyword}%"
            cursor.execute(q, (val, val, val))
            rows = cursor.fetchall()
            if rows:
                for row in rows:
                    print(row)
            else:
                print("No matching books found.")
        except Error as e:
            print("Error:", e)
        finally:
            if cursor:
                cursor.close()
            if conn:
                conn.close()

    def update_book(self, book_id, title, author, isbn, copies):
        conn = None
        cursor = None
        try:
            conn = self.db.get_connection()
            cursor = conn.cursor()
            cursor.execute(
                """
                UPDATE books
                SET title=%s, author=%s, isbn=%s, copies=%s, available_copies=%s
                WHERE book_id=%s
                """,
                (title, author, isbn, copies, copies, book_id)
            )
            conn.commit()
            if cursor.rowcount > 0:
                print("Book updated successfully.")
            else:
                print("Book not found.")
        except IntegrityError:
            print("Update failed: ISBN already exists.")
        except Error as e:
            print("Error:", e)
        finally:
            if cursor:
                cursor.close()
            if conn:
                conn.close()

    def delete_book(self, book_id):
        conn = None
        cursor = None
        try:
            conn = self.db.get_connection()
            cursor = conn.cursor()
            cursor.execute("DELETE FROM books WHERE book_id=%s", (book_id,))
            conn.commit()
            if cursor.rowcount > 0:
                print("Book deleted successfully.")
            else:
                print("Book not found.")
        except IntegrityError:
            print("Cannot delete book: it is referenced by a transaction.")
        except Error as e:
            print("Error:", e)
        finally:
            if cursor:
                cursor.close()
            if conn:
                conn.close()


