#2.Count vowels and consonants
s = str(input("enter a name:"))
vowels = "aeiouAEIOU"
v_count = c_count = 0
for ch in s:
    if ch.isalpha():
        if ch in vowels:
            v_count += 1
        else:
            c_count += 1
print("Vowels:", v_count, "Consonants:", c_count)
