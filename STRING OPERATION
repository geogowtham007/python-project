#15.Find duplicate characters
s = "programming"
seen = set()
duplicates = set()
for ch in s:
    if ch in seen:
        duplicates.add(ch)
    else:
        seen.add(ch)
print("Duplicates:", "".join(duplicates))

#16.Reverse each word (not full string)
s = "hello world"
words = s.split()
result = ""
for w in words:
    rev = ""
    for ch in w:
        rev = ch + rev
    result += rev + " "
print(result.strip())

